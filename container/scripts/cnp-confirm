#!/usr/bin/env bash
set -euo pipefail

if [[ $# -lt 2 ]]; then
  echo "usage: cnp-confirm <command> <reason>" >&2
  exit 1
fi

COMMAND="$1"
REASON="$2"
IPC_ROOT="${IPC_DIR:-/workspace/ipc}"
CHAT_JID="${CNP_BOT_CHAT_JID:-}"
REQUEST_DIR="${IPC_ROOT}/confirm_requests"
RESPONSE_DIR="${IPC_ROOT}/confirm_responses"

mkdir -p "$REQUEST_DIR" "$RESPONSE_DIR"

# Generate a UUID without Node.js
if command -v uuidgen &>/dev/null; then
  REQUEST_ID="$(uuidgen | tr '[:upper:]' '[:lower:]')"
else
  REQUEST_ID="$(cat /proc/sys/kernel/random/uuid)"
fi

REQUEST_FILE="${REQUEST_DIR}/${REQUEST_ID}.json"
REQUEST_TMP_FILE="${REQUEST_FILE}.tmp"

# Build JSON with printf — no Node.js required.
# Values are escaped by replacing \ with \\ and " with \".
escape_json() {
  printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

CMD_ESC="$(escape_json "$COMMAND")"
REASON_ESC="$(escape_json "$REASON")"
JID_ESC="$(escape_json "$CHAT_JID")"

printf '{"type":"confirm_bash","requestId":"%s","chatJid":"%s","command":"%s","reason":"%s"}' \
  "$REQUEST_ID" "$JID_ESC" "$CMD_ESC" "$REASON_ESC" > "$REQUEST_TMP_FILE"
mv "$REQUEST_TMP_FILE" "$REQUEST_FILE"

RESPONSE_FILE="${RESPONSE_DIR}/${REQUEST_ID}.json"
TIMEOUT_SECONDS="${CNP_CONFIRM_TIMEOUT_SECONDS:-300}"
START_TS="$(date +%s)"

while true; do
  if [[ -f "$RESPONSE_FILE" ]]; then
    # Read the approved field with grep/sed — no Node.js
    APPROVED="$(grep -o '"approved":[^,}]*' "$RESPONSE_FILE" 2>/dev/null | sed 's/"approved"://' | tr -d ' ' || true)"
    if [[ -n "$APPROVED" ]]; then
      rm -f "$RESPONSE_FILE"
      if [[ "$APPROVED" == "true" ]]; then
        exit 0
      fi
      exit 2
    fi

    # Host may still be writing the JSON file. Retry on the next poll tick.
    sleep 0.1
    continue
  fi

  NOW_TS="$(date +%s)"
  if (( NOW_TS - START_TS >= TIMEOUT_SECONDS )); then
    echo "Timed out waiting for confirm response" >&2
    exit 3
  fi
  sleep 0.5
done
